# Copy into Coolify's environment for the zero-cache resource.

# Neon app database — DIRECT (non-pooled) connection, logical replication enabled.
# This is the same value as the app's POSTGRES_URL_NON_POOLING.
ZERO_UPSTREAM_DB=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/dbname?sslmode=require

# Zero bookkeeping DBs (the local zero-db service in docker-compose.yml).
ZERO_DB_PASSWORD=change-me
ZERO_CVR_DB=postgresql://zero:c6125d124641625cf23d2e70b56063d4@zero-db:5432/zero_cvr
ZERO_CHANGE_DB=postgresql://zero:c6125d124641625cf23d2e70b56063d4@zero-db:5432/zero_change

# Callbacks into the Vercel app.
ZERO_QUERY_URL=https://workout.zack-bumm.com/api/zero/query
ZERO_MUTATE_URL=https://workout.zack-bumm.com/api/zero/mutate

# NOTE: ZERO_AUTH_SECRET is intentionally NOT set for zero-cache — it forwards
# tokens to the app, which verifies them. The app (Vercel) still needs its own
# ZERO_AUTH_SECRET. Setting it here only triggers a deprecation warning.

# Protects zero-cache's admin/debug endpoints. Required in production mode.
ZERO_ADMIN_PASSWORD=generate-another-random-string
